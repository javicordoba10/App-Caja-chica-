rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && getUserData().get('role', 'user') == 'superadmin';
    }
    
    function getUserCompanyId() {
      return getUserData().get('companyId', 'alm_agro');
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (getUserData().get('role', 'user') == 'admin' && getUserCompanyId() == resource.data.get('companyId', 'alm_agro'))
      );
    }
    
    // Movements collection
    match /movements/{movementId} {
      allow read, write: if request.auth != null && (
        isSuperAdmin() ||
        (resource == null && request.resource.data.userId == request.auth.uid) || 
        (resource != null && (resource.data.userId == request.auth.uid || 
         (getUserData().get('role', 'user') == 'admin' && getUserCompanyId() == resource.data.get('companyId', 'alm_agro'))))
      );
    }

    // Company Config
    match /companies_config/{companyId} {
      allow read: if request.auth != null; 
      allow write: if isSuperAdmin();
    }
  }
}
